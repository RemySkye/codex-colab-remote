if subprocess.run(["id", "-u", "codex"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode != 0:
    run(["useradd", "-m", "-s", "/bin/bash", "codex"])
# Preserve the existing home, tmux sessions, logs, and checkpoints on a same-VM rerun.
